SUPABASE_URL=https://your-project.supabase.co
# Required for Supabase Auth in the browser and /login.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Use only one of these server-side keys.
# Do not use sb_publishable or the anon/public key here.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_SECRET_KEY=your-supabase-secret-key

# OpenAI server-side integration for AI enrichment and proposal drafting.
OPENAI_API_KEY=your-openai-api-key
OPENAI_CLASSIFIER_MODEL=gpt-5-nano
OPENAI_WRITER_MODEL=gpt-4o-mini
# Opcionales para afinar costo y latencia:
# OPENAI_TIMEOUT_MS=20000
# OPENAI_IMPORT_CHUNK_SIZE=8
